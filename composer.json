{
    "name": "mydnic/kanpen",
    "description": "Easily Manage Internal Newsletter Subscribers in Laravel — with campaigns, mail sending, and tracking",
    "keywords": [
        "laravel",
        "newsletter",
        "subscribers",
        "email",
        "campaigns",
        "tracking"
    ],
    "license": "MIT",
    "homepage": "https://github.com/mydnic/kanpen",
    "authors": [
        {
            "name": "Clément Rigo",
            "email": "rigoclement@mydnic.be"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": ">=10.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Mydnic\\Kanpen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mydnic\\Kanpen\\Test\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mydnic\\Kanpen\\KanpenServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
